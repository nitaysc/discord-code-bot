DISCORD_TOKEN=your_discord_bot_token_here

# AI provider (only one needed). Default is GitHub Models.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
AI_MODEL=gpt-4o-mini

# Optional AI fallbacks
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_API_KEY=your_cloudflare_key_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Optional web search APIs (for reliable real-time info)
# Free tiers: SerpApi 100/mo, Bing 1000/mo, Brave 2000/mo
SERPAPI_API_KEY=your_serpapi_key_here
BING_API_KEY=your_bing_search_key_here
BRAVE_API_KEY=your_brave_search_key_here

# Optional persistent database path.
# On hosts that wipe the project folder on redeploy, set this to a persistent directory.
# DB_PATH=/home/container/data/bot.db

# Optional PostgreSQL database URL (e.g., Supabase/Neon).
# If set, the bot uses Postgres instead of SQLite and XP persists across redeploys.
# DATABASE_URL=postgresql://user:password@host:5432/database
